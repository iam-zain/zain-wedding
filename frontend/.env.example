# Copy to .env.local and fill in for connecting to the real backend.
# When VITE_API_BASE_URL is empty the app runs in LOCAL mode:
#   - likes increment optimistically (persisted in localStorage)
#   - comments are stored in localStorage so they still appear
# This keeps the app fully demoable without any AWS backend.

# Base URL of the HTTP API Gateway (no trailing slash), e.g. https://abc123.execute-api.ap-south-1.amazonaws.com
VITE_API_BASE_URL=

# x-api-key for write endpoints (POST /like, POST /comment)
VITE_API_KEY=

# Where posts.json / stories.json + images are served from.
# Local dev default is "/data" (served from public/). In prod set to the CloudFront data URL.
VITE_DATA_BASE_URL=/data

# Public site URL used for Web Share. Defaults to window.location.origin if empty.
VITE_SITE_URL=
